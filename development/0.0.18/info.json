  {
    "version": "0.0.18",
    "branch": "development",
    "commit": "9f0cca7f22e8d1c577ef1f87d5501b57015d8599",
    "shortCommit": "9f0cca7",
    "buildTime": "2026-04-14T14:17:30Z"
  }
  EOF

  VERSION_DIR="releases/development/0.0.18"
  export FILES_JSON="{}"

  for f in ; do
    REL_PATH=
    HASH=
    MD5_HASH=
    FILES_JSON={"":{"path":"","sha256":"","md5":""}}
  done

  bun -e "
    const fs = require('fs');

    const meta = {
      version: process.env.VERSION,
      branch: process.env.BRANCH,
      commit: process.env.COMMIT,
      shortCommit: process.env.SHORT_COMMIT,
      buildTime: new Date().toISOString(),
      files: JSON.parse(process.env.FILES_JSON || '{}')
    };

    fs.writeFileSync(
      process.env.BRANCH_TARGET + '/latest.json',
      JSON.stringify(meta, null, 4)
    );
  "
