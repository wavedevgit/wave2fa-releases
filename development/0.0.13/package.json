{
    "name": "wave2fa",
    "version": "0.0.13",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "dev": "bun run src/main.ts --demo",
        "test": "bun run src/main.ts --demo",
        "build": "esbuild src/main.ts --format=esm --bundle --platform=node --outfile=dist/bundle.js --external:blessed --minify --sourcemap --external:./node_modules/*",
        "build:ts": "tsc",
        "build:binary:linux": "bun build ./dist/main.js --compile --outfile=dist/binaries/wave2fa-linux-x64 --target=bun-linux-x64 --external pty.js --external term.js",
        "build:binary:linux:arm64": "bun build ./dist/main.js --compile --outfile=dist/binaries/wave2fa-linux-arm64 --target=bun-linux-arm64 --external pty.js --external term.js",
        "build:binary:mac": "bun build ./dist/main.js --compile --outfile=dist/binaries/wave2fa-macos-x64 --target=bun-macos-x64 --external pty.js --external term.js",
        "build:binary:mac:arm64": "bun build ./dist/main.js --compile --outfile=dist/binaries/wave2fa-macos-arm64 --target=bun-macos-arm64 --external pty.js --external term.js",
        "build:binary:win": "bun build ./dist/main.js --compile --outfile=dist/binaries/wave2fa-windows-x64.exe --target=bun-windows-x64 --external pty.js --external term.js",
        "build:binary:win:arm64": "bun build ./dist/main.js --compile --outfile=dist/binaries/wave2fa-windows-arm64.exe --target=bun-windows-arm64 --external pty.js --external term.js",
        "lint": "tsc --noEmit",
        "postinstall": "patch-package"
    },
    "bin": {
        "wave2fa": "./dist/bundle.js"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "resolutions": {},
    "dependencies": {
        "@node-rs/argon2": "^2.0.2",
        "@types/blessed": "^0.1.27",
        "argon2": "^0.44.0",
        "blessed": "^0.1.81",
        "canvas": "^3.2.1",
        "clipboardy": "^5.3.1",
        "esbuild": "^0.27.2",
        "jimp": "^1.6.0",
        "jsqr": "^1.4.0",
        "jsqrcode": "^0.0.7",
        "node-file-dialog": "^1.0.3",
        "patch-package": "^8.0.1",
        "prettier": "^3.8.2",
        "protobufjs": "^8.0.0",
        "speakeasy": "^2.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bun": "^1.3.11",
        "@types/node": "^25.5.2",
        "@types/speakeasy": "^2.0.10",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "eslint": "^10.2.0",
        "globals": "^17.4.0",
        "typescript-eslint": "^8.58.0"
    },
    "private": false,
    "peerDependencies": {
        "typescript": "^5"
    }
}